def encrypt(key):
  text=input()
  for char in text:
    if char.isupper():
      print(chr((ord(char)+key-65)% 26+65),end="")
    elif char.islower():
      print(chr((ord(char)+key-97)%26+65),end="")
    else:
      print(char)
def decrypt(key):
  text=input()
  for char in text:
    if char.isupper():
      print(chr((ord(char)-key-65)% 26+65),end="")
    elif char.islower():
      print(chr((ord(char)-key-97)% 26+97),end="")
